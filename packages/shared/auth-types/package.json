{
  "name": "@lovett/auth-types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript types + Zod schemas: User, Session, IdentityRPC contract. Imported by identity-svc, auth-gateway, and @lovett/auth SDK.",
