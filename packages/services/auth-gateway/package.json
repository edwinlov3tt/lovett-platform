{
  "name": "@lovett/auth-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Public auth gateway. Hono Worker at auth.edwinlovett.com. Owns HTTP, cookies, HTML auth pages, Resend sends. Calls identity-svc via RPC; never touches D1 directly.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo .wrangler"
  },
  "dependencies": {
    "@lovett/auth-types": "workspace:*",
    "@lovett/db-utils": "workspace:*",
    "hono": "^4.6.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.38",
    "@cloudflare/workers-types": "^4.20241218.0",
    "@lovett/identity-svc": "workspace:*",
    "typescript": "^5.7.2",
    "vitest": "2.1.8",
    "wrangler": "^3.99.0"
  }
}
