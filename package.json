{
  "name": "lovett-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Lovett Platform — shared microservices (auth, email, etc.) built on Cloudflare Workers RPC. First service: auth.edwinlovett.com.",
  "packageManager": "pnpm@10.18.1",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
